# B-694 build-environment config — copy to a private file (e.g. ~/.harmony-container.env,
# NEVER committed) and pass with: docker run --env-file <file>
# Everything machine- or environment-specific enters HERE; nothing is baked
# into the image and nothing is hand-edited inside the container.

# --- READ PLANE -------------------------------------------------------------
# Which Harmony board / Supabase project the worker's MCP + CLI talk to.
# NOT deploy targeting: deploys happen in CI from GitHub secrets after a
# merge. HARMONY_TARGET=staging does NOT deploy anything to staging — the
# container only ever pushes a branch and opens a PR.
#   prod    — the real board (default; where tickets live)
#   staging — B-488-style plugin-change dogfood only
#   custom  — also set HARMONY_SUPABASE_URL (+ anon key)
HARMONY_TARGET=prod

# Board API token for the chosen target.
HARMONY_API_TOKEN=

# Anon key for the chosen target (Supabase dashboard > Project Settings > API
# keys). Required for staging/custom; optional for prod (baked default).
#HARMONY_SUPABASE_ANON_KEY=

# custom target only:
#HARMONY_SUPABASE_URL=

# --- GIT --------------------------------------------------------------------
# GitHub token able to clone/push ycomplex repos. Founder PAT for dogfood;
# B-695's bot credentials drop into this SAME key later (soft dependency).
GIT_TOKEN=
GIT_USER_NAME=
GIT_USER_EMAIL=

# Repos/refs to clone at start (defaults shown).
#WEB_REF=main
#PLUGIN_REF=main
#WORKSPACE_REF=main

# --- AGENT LAYER ONLY -------------------------------------------------------
# PRIMARY headless auth: a long-lived Claude Code OAuth token (~1 year),
# minted on any machine with your Max subscription via: claude setup-token
# This keeps headless `claude -p` runs on subscription auth.
CLAUDE_CODE_OAUTH_TOKEN=

# FALLBACK ONLY — an Anthropic API key OVERRIDES subscription auth and bills
# per-token. Leave commented out unless you explicitly want API billing; a
# set-but-empty value would shadow the OAuth token (provision.sh unsets empty
# values defensively, same class as the anon-key guard).
#ANTHROPIC_API_KEY=

# Headless permission envelope (default set in the agent image; the container
# is the sandbox that makes the broad grant safe).
#CLAUDE_HEADLESS_FLAGS=--dangerously-skip-permissions
